# salon_gateway — copy keys into src/agent/.env (or export). Prefix: SALON_

SALON_LOG_LEVEL=INFO

# Optional: scripts/test_salon_gateway.py (not read by the gateway process)
# SALON_TEST_BASE_URL=https://your-public-domain.example

# 企业微信自建应用「接收消息」回调
# 生产：密文模式（SALON_WECOM_PLAINTEXT=false）并填写三项
SALON_WECOM_PLAINTEXT=true
SALON_WECOM_TOKEN=
SALON_WECOM_ENCODING_AES_KEY=
SALON_WECOM_CORP_ID=

# Dify 对话 / Chatflow 应用 API（应用设置 → API 访问）
# 发型效果图：若 HTTP 传入 upload.dify.ai 图片链，网关需用本 Key 拉取原图再调万相。
# Chatflow 开始节点必填变量：在此提供默认值（JSON），与 Dify 变量名一致
# 例：SALON_DIFY_DEFAULT_INPUTS_JSON={"lang":"zh"}
# Dify 若返回 Workflow not published：在控制台对该 Chatflow 点「发布」后再调 API
SALON_DIFY_DEFAULT_INPUTS_JSON={}
SALON_DIFY_API_BASE=https://api.dify.ai/v1
SALON_DIFY_API_KEY=
SALON_DIFY_USER_PREFIX=wecom

# 门店/项目下拉选项（与 booking 相同 Bearer）：GET /internal/booking-options?store_q=东&service_q=染
# 数据来自飞书表中 feishu_field_map 的 store（单选）、service（多选）列定义；用于 H5/小程序/Dify 外部数据源做搜索筛选
#
# Dify HTTP 工具回调：POST /internal/booking；留空则关闭该路由
# 必须与 Dify「提交预约」HTTP 节点里 Bearer 的密钥完全一致（与导入 DSL 默认 41 字符占位符无关）。
# 若日志出现 parsed_token_len=41：多为 Dify 仍使用模板占位符 REPLACE_WITH_SALON_INTERNAL_BOOKING_TOKEN，请在 Dify 中改为与本变量相同的值。
# 401 时日志含 parsed_token_sha256_12 / accepted_token_sha256_12；本地比对：python -c "import hashlib;print(hashlib.sha256('粘贴SALON值'.encode()).hexdigest()[:12])"
SALON_INTERNAL_BOOKING_TOKEN=

# 模拟企微文本 → Dify（JSON）：POST /simulate/wecom-text；生产务必留空
# 鉴权：Authorization: Bearer <同此值> 或 X-Salon-Token
# 本地 CLI：python scripts/simulate_wecom.py 你好 | python scripts/simulate_wecom.py --chat
# SALON_SIMULATE_TOKEN=

# 通义万相（发型效果图生成，可选）
# 不配置则 POST /internal/hairstyle-preview 返回 503，Dify 中该分支跳过。
SALON_DASHSCOPE_API_KEY=
# SALON_WANXIANG_MODEL=wanx2.1-imageedit
# 万相 2.7 图+文编辑（单独 API，无 SegmentHair mask）：wan2.7-image 或 wan2.7-image-pro
# SALON_WANXIANG_MODEL=wan2.7-image-pro
# 国内账号（默认）：https://dashscope.aliyuncs.com/api/v1
# 国际站账号（新加坡）：https://dashscope-intl.aliyuncs.com/api/v1
# SALON_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 阿里云 RAM AccessKey（SegmentHair 发区精准分割，可选，推荐配置）
# 与 DashScope API Key 不同！在阿里云控制台 → RAM 访问控制 → 用户 → 安全信息管理 创建
# 需开通：视觉智能开放平台 → 图像分割 → 头发分割（SegmentHair）
# 配置后发型图生成精度显著提升（仅修改头发区域，面部/背景完全保留）
# 未配置则自动降级为 description_edit 通用模式（精度较低）
SALON_ALIYUN_ACCESS_KEY_ID=
SALON_ALIYUN_ACCESS_KEY_SECRET=
# SALON_ALIYUN_IMAGESEG_REGION=cn-shanghai

# 飞书多维表（可选）。不配则预约仅打日志。
SALON_FEISHU_APP_ID=
SALON_FEISHU_APP_SECRET=
SALON_FEISHU_BITABLE_APP_TOKEN=
SALON_FEISHU_BITABLE_TABLE_ID=
# JSON：BookingDraft 字段名 -> 飞书列名
# service 映射飞书「多选」列：请求 JSON 用数组，如 ["染发","烫发"]；单字符串表示只选一个
# 例：{"phone":"手机号","store":"门店","service":"项目","slot_text":"意向时间","color_summary":"发色方案","status":"状态","channel":"渠道","external_user_id":"外部ID","notes":"备注","history_summary":"染发史"}
SALON_FEISHU_FIELD_MAP_JSON={}
