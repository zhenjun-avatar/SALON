# 网关根路径（含 /salon）。留空则开发环境默认使用相对路径 `/salon`（配合 Vite 代理）。
VITE_SALON_API_BASE=

# 与网关 SALON_SIMULATE_TOKEN 一致（仅开发联调；生产请换 JWT + 新路由）
VITE_SALON_SIMULATE_TOKEN=

# 与网关 SALON_INTERNAL_BOOKING_TOKEN 中任一段一致；配置后左侧可勾选家居素材（GET /internal/furnishing-assets）
VITE_SALON_INTERNAL_TOKEN=

# 可选：开发时代理到本机网关（默认与 `python -m salon_gateway` 一致：8765）
# 浏览器请求 /salon/* → target + /salon/*
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8765
